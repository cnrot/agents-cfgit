+  // 第二次初始化
+  const second = initGit(repoDir);
+  assert(second.initialized === false, '第二次 initialized 应为 false');
+  assert(second.skipped === true, '第二次 skipped 应为 true');
+  assert(second.message === 'git 仓库已存在', '第二次 message 应提示已存在');
