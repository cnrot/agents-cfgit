+  assert(typeof result.skipped === 'boolean', '应返回 skipped 布尔值');
+  assert(typeof result.message === 'string', '应返回 message 字符串');
+});
+
+console.log(`\n结果: ${passed} 通过, ${failed} 失败`);
+process.exit(failed > 0 ? 1 : 0);
