{
  "name": "agentcfg",
  "version": "0.1.12",
  "description": "基于 Git 的 AI 工具配置文件版本控制系统",
  "type": "module",
  "bin": {
    "agentcfg": "bin/agentcfg.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "keywords": [
    "git",
    "ai",
    "version-control",
    "backup",
    "claude-code",
    "cursor",
    "codex",
    "opencode"
  ],
  "scripts": {
    "test": "echo 'no tests configured'",
    "prepublishOnly": "npm test"
  },
  "files": [
    "bin/",
    "src/core/commit.js",
    "src/core/init.js",
    "src/core/log.js",
    "src/core/diff.js",
    "src/core/squash.js",
    "src/hooks/claude.js",
    "src/hooks/cursor.js",
    "src/hooks/codex.js",
    "src/hooks/opencode.js",
    "src/install.js",
    "src/uninstall.js",
    "src/recover.js",
    "src/verify.js",
    "templates/",
    "SKILL.md",
    "README.md",
    "UNINSTALL.md",
    "LICENSE"
  ]
}
